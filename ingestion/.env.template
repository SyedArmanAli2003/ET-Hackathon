# ─────────────────────────────────────────────────────────────────────────────
# Air Quality Ingestion — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Security critical ─────────────────────────────────────────────────────────
# NEVER use the postgres superuser for application connections.
# A restricted role (app_ingestion) has been created with only the privileges
# the ingestion pipeline needs (SELECT / INSERT on pipeline tables).
#
# Connection format (Session mode — direct DB, NOT the pooled 6543 port):
#   postgresql://app_ingestion:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
#
# Find your project ref in: Supabase Dashboard → Project Settings → Database
# The sslmode=require is REQUIRED for secure connections.
SUPABASE_DB_URL=postgresql://app_ingestion:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# OpenAQ API key (free tier available at https://explore.openaq.org/register)
OPENAQ_API_KEY=your_openaq_api_key_here

# Optional: override the log level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
